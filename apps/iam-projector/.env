# Application
NODE_ENV=development
PORT=3002
HOST=0.0.0.0

# RabbitMQ
MQ_HOST=127.0.0.1
MQ_PORT=\${RABBITMQ_AMQP_PORT}
MQ_USERNAME=\${RABBITMQ_USERNAME}
MQ_PASSWORD=\${RABBITMQ_PASSWORD}
MQ_EXCHANGE=iam.events

# PostgreSQL (Write DB - Snapshots)
DB_HOST=127.0.0.1
DB_PORT=\${POSTGRES_PORT}
DB_USERNAME=\${POSTGRES_USERNAME}
DB_PASSWORD=\${POSTGRES_PASSWORD}
DB_DATABASE=iam-write

# Redis (Cache)
CACHE_HOST=127.0.0.1
CACHE_PORT=\${REDIS_PORT}
CACHE_PASSWORD=\${REDIS_PASSWORD}
CACHE_DB=0


# Elasticsearch (Search Index)
ES_HOST=127.0.0.1
ES_PORT=${ELASTICSEARCH_PORT}
ES_USERNAME=${ELASTICSEARCH_USERNAME}
ES_PASSWORD=${ELASTICSEARCH_PASSWORD}

# =============================================================================
# Observability - Logging (Pino)
# =============================================================================
LOG_LEVEL=info
LOG_PRETTY=true
LOG_REDACT_PATHS=password,secret,token,authorization
LOG_ERROR_KEY=err
LOG_CONTEXT_KEY=context

# =============================================================================
# Observability - Tracing (OpenTelemetry)
# =============================================================================
OTEL_ENABLED=false
OTEL_SERVICE_NAME=iam-projector-worker
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_SAMPLER=always_on
OTEL_TRACES_SAMPLER_ARG=1.0
