# Application
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# EventStoreDB
EVENTSTOREDB_HOST=127.0.0.1
EVENTSTOREDB_PORT=${EVENTSTOREDB_PORT}
EVENTSTOREDB_USERNAME=${EVENTSTOREDB_USERNAME}
EVENTSTOREDB_PASSWORD=${EVENTSTOREDB_PASSWORD}

# RabbitMQ
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=${RABBITMQ_PORT}
RABBITMQ_USERNAME=${RABBITMQ_USERNAME}
RABBITMQ_PASSWORD=${RABBITMQ_PASSWORD}
RABBITMQ_EXCHANGE=iam.events

# PostgreSQL (Write DB - Snapshots)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=${POSTGRES_PORT}
POSTGRES_USERNAME=${POSTGRES_USERNAME}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_DATABASE=iam_write

# Redis (Cache)
REDIS_HOST=127.0.0.1
REDIS_PORT=${REDIS_PORT}
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_DB=0
