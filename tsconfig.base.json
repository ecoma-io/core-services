{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": true,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@ecoma-io/domain": ["packages/domain/src/index.ts"],
      "@ecoma-io/interactor": ["packages/interactor/src/index.ts"],
      "@ecoma-io/nx-typescript": ["packages/nx-typescript/src/index.ts"],
      "@ecoma-io/jest-helpers": ["packages/jest-helpers/src/index.ts"],
      "@ecoma-io/common": ["packages/common/src/index.ts"],
      "@ecoma-io/expand-env": ["packages/expand-env/src/index.ts"],
      "@ecoma-io/eslint-plugin-monorepo": [
        "packages/eslint-plugin-monorepo/src/index.ts"
      ],
      "@ecoma-io/nx-docker": ["packages/nx-docker/src/index.ts"],
      "@ecoma-io/nx-typeorm": ["packages/nx-typeorm/src/index.ts"],
      "@ecoma-io/nestjs-helpers": ["packages/nestjs-helpers/src/index.ts"],
      "@ecoma-io/integration-hybridize": [
        "packages/integration-hybridize/src/index.ts"
      ],
      "@ecoma-io/integration-environment": [
        "libs/integration-environment/src/index.ts"
      ],
      "@ecoma-io/parse-env-file": ["packages/parse-env-file/src/index.ts"],
      "@ecoma-io/iam-domain": ["libs/iam-domain/src/index.ts"],
      "@ecoma-io/adapter": ["packages/adapter/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
